.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  overflow-y: auto;
}
  
.camera-wrap {
  width: 100%;
  height: 56vh;
  min-height: 460rpx;
  max-height: 700rpx;
  flex-shrink: 0;
  overflow: hidden;
  background-color: #000;
}
  
.camera-view {
  width: 100%;
  height: 100%;
}
  
.auth-tip {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx;
  color: #444;
  background-color: #fff;
  box-sizing: border-box;
}
  
.control-bar {
  display: flex;
  justify-content: space-around;
  margin: 10rpx 0 6rpx;
  flex-wrap: wrap;
}
  
.control-bar button {
  margin: 8rpx;
}
  
.slider-container {
  padding: 22rpx 32rpx;
  margin: 10rpx 20rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
  
.slider-container text {
  display: block;
  margin-bottom: 12rpx;
}
  
.slider-container slider {
  width: 100%;
}
  
.switch-line {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
  
.result {
  text-align: center;
  font-size: 36rpx;
  margin-top: 8rpx;
  padding-bottom: 8rpx;
}
  
.result text {
  display: block;
  margin: 6rpx 0;
}
  
.result .source {
  color: #666;
  font-size: 28rpx;
}
  
.status {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin: 10rpx 20rpx 24rpx;
  padding: 10rpx;
}
  
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}
  
