<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 摄像头区域 -->
  <camera
    id="camera"
    device-position="{{devicePosition}}"
    flash="off"
    frame-size="small"
    bindinitdone="onCameraInit"
    binderror="onCameraError"
    style="width:100%; height:60vh;"
  ></camera>

  <!-- 控制栏 -->
  <view class="control-bar">
    <button type="primary" bindtap="switchCamera">切换摄像头</button>
    <button bindtap="chooseImage">从相册选择</button>
    <button bindtap="manualCapture">拍照识别</button>  <!-- 新增手动拍照按钮 -->
  </view>

  <!-- 频率调节滑块（用于自动拍照模式） -->
  <view class="slider-container">
    <text>自动拍照频率：{{fps}} 次/秒</text>
    <slider min="0.5" max="2" step="0.5" value="{{fps}}" bindchange="onFpsChange" show-value></slider>
    <switch checked="{{autoMode}}" bindchange="toggleAutoMode" /> 自动模式
  </view>

  <!-- 识别结果显示 -->
  <view class="result" wx:if="{{result}}">
    <text>手势：{{result.letter}}</text>
    <text>置信度：{{result.confidencePercent}}%</text>
  </view>
</view>