<!-- pages/index/index.wxml -->
<view class="container">
  <view class="camera-wrap">
    <camera
      wx:if="{{hasCameraAuth}}"
      id="camera"
      class="camera-view"
      device-position="{{devicePosition}}"
      flash="off"
      frame-size="medium"
      bindinitdone="onCameraInit"
      binderror="onCameraError"
    ></camera>

    <view wx:else class="auth-tip">
      <text>未开启相机权限，手势识别无法使用</text>
      <button type="primary" open-type="openSetting" bindopensetting="onOpenSetting">去开启权限</button>
    </view>
  </view>

  <view class="result" wx:if="{{result}}">
    <text>识别结果：{{result.letter}}</text>
    <text>置信度：{{result.confidencePercent}}%</text>
    <text class="source">来源：{{result.source}}</text>
  </view>

  <view class="status" wx:if="{{statusText}}">
    <text>{{statusText}}</text>
  </view>

  <view class="control-bar">
    <button type="primary" bindtap="switchCamera">切换摄像头</button>
    <button bindtap="chooseImage">相册识别</button>
    <button type="warn" bindtap="manualCapture">拍照识别</button>
  </view>

  <view class="slider-container">
    <text>自动识别频率：{{fps}} 次/秒</text>
    <slider min="0.5" max="2" step="0.5" value="{{fps}}" bindchange="onFpsChange" show-value></slider>
    <view class="switch-line">
      <switch checked="{{autoMode}}" bindchange="toggleAutoMode" />
      <text>自动模式</text>
    </view>
  </view>

  <canvas type="2d" id="bufferCanvas" class="hidden-canvas"></canvas>
</view>
